{% extends 'layouts/base.twig' %}

{% block title %}Энциклопедия здоровья — {{ siteName }}{% endblock %}

{% block content %}

<div class="cont-border-bottom">
  <div class="container">

    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <a href="index.html">Главная</a> / Энциклопедия
    </nav>

    <h1 class="enc-title">Энциклопедия здоровья <span class="enc-title__sep">|</span> Клиника Гармония</h1>

    <div class="enc-filters">

      <div class="enc-filters__dropdown-wrap">
        <svg class="enc-filters__icon" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <path d="M6 2v5a4 4 0 0 0 8 0V2"/>
          <path d="M10 11v3a6 6 0 0 0 12 0v-2"/>
          <circle cx="22" cy="12" r="1.5" fill="#888" stroke="none"/>
        </svg>
        <select class="enc-filters__select">
          <option value="">Все категории</option>
          <option>Гастроэнтерология</option>
          <option>Кардиология</option>
          <option>Оториноларингология</option>
          <option>Флебология</option>
          <option>Неврология</option>
          <option>Эндокринология</option>
          <option>Ортопедия</option>
          <option>Урология</option>
          <option>Гинекология</option>
          <option>Пульмонология</option>
          <option>Иммунология</option>
        </select>
        <svg class="enc-filters__chevron" viewBox="0 0 20 20" fill="none" stroke="#555" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
          <polyline points="4 7 10 13 16 7"/>
        </svg>
      </div>

      <div class="enc-filters__search-wrap">
        <svg class="enc-filters__icon" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input type="text" class="enc-filters__input" placeholder="Найти статью энциклопедии">
      </div>

    </div>

    {% set articles = [
      { title: 'Боль в ногах: причины и лечение',  category: 'Без категории',        excerpt: 'Боль в ногах – явление, способное доставить значительный дискомфорт.' },
      { title: 'Тянет внизу живота',               category: 'Гастроэнтерология',    excerpt: 'Если тянет низ живота, причины могут объясняться природными физиологическими процессами, но также и быть предвестниками серьезных заболеваний.' },
      { title: 'Аритмия сердца',                   category: 'Кардиология',          excerpt: 'Аритмии в современной медицинской практике встречаются довольно часто. Порой они действительно создают серьезную угрозу для жизни пациента.' },
      { title: 'Шум в ушах',                       category: 'Оториноларингология',  excerpt: 'Если шумит в ушах, то нужно искать источник этого расстройства. Это состояние также носит название тиннитус. Расстройство может приводить к нервозности, нарушению сна, работоспособности.' },
      { title: 'Варикоз нижних конечностей',       category: 'Флебология',           excerpt: 'Варикозное расширение вен — распространённое заболевание, при котором поверхностные вены деформируются и теряют эластичность.' },
      { title: 'Мигрень: симптомы и лечение',      category: 'Неврология',           excerpt: 'Мигрень — неврологическое заболевание, характеризующееся повторяющимися интенсивными приступами головной боли.' },
      { title: 'Сахарный диабет 2 типа',           category: 'Эндокринология',       excerpt: 'Сахарный диабет 2 типа — хроническое заболевание, при котором организм недостаточно эффективно использует инсулин.' },
      { title: 'Боль в пояснице',                  category: 'Ортопедия',            excerpt: 'Боль в пояснице — одна из наиболее частых причин обращения к врачу. Может быть вызвана мышечным спазмом или заболеваниями позвоночника.' },
      { title: 'Простатит: симптомы',              category: 'Урология',             excerpt: 'Простатит — воспаление предстательной железы, одно из наиболее распространённых урологических заболеваний у мужчин.' },
      { title: 'Цистит у женщин',                  category: 'Гинекология',          excerpt: 'Цистит — воспалительное заболевание мочевого пузыря, которое значительно чаще встречается у женщин, чем у мужчин.' },
      { title: 'Гастрит: причины и лечение',       category: 'Гастроэнтерология',    excerpt: 'Гастрит — воспаление слизистой оболочки желудка, которое может протекать как в острой, так и в хронической форме.' },
      { title: 'Бронхит',                          category: 'Пульмонология',        excerpt: 'Бронхит — воспалительное заболевание бронхов, сопровождающееся кашлем с отхождением мокроты.' },
      { title: 'Синусит',                          category: 'Оториноларингология',  excerpt: 'Синусит — воспаление слизистой оболочки одной или нескольких придаточных пазух носа.' },
      { title: 'Артроз суставов',                  category: 'Ортопедия',            excerpt: 'Артроз — дегенеративное заболевание суставов, при котором происходит постепенное разрушение хрящевой ткани.' },
      { title: 'Аллергический ринит',              category: 'Иммунология',          excerpt: 'Аллергический ринит — воспаление слизистой носа, вызванное воздействием аллергенов: пыльцы, пыли, шерсти животных.' },
      { title: 'Гипертония',                       category: 'Кардиология',          excerpt: 'Гипертония — стойкое повышение артериального давления выше нормальных значений, требующее наблюдения и лечения.' }
    ] %}

    <div class="enc-grid">
      {% for item in articles %}
      {% set imgNum = ((loop.index - 1) % 4) + 1 %}
      <div class="enc-card">
        <div class="enc-card__image-wrap">
          <img src="/images/encyclopedia/i{{ imgNum }}.png" alt="{{ item.title }}">
        </div>
        <a href="#" class="enc-card__title">{{ item.title }}</a>
        <span class="enc-card__category">{{ item.category }}</span>
        <p class="enc-card__excerpt">{{ item.excerpt }}</p>
      </div>
      {% endfor %}
    </div>

    <div class="list-footer">
      <a href="#" class="btn-show-more">Показать еще</a>

      <nav class="pg" aria-label="Пагинация">
        <a href="#" class="pg__item" aria-label="Назад">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </a>
        <a href="#" class="pg__item pg__item--active">1</a>
        <a href="#" class="pg__item">2</a>
        <span class="pg__item pg__item--dots">...</span>
        <a href="#" class="pg__item pg__item--filled" aria-label="Вперёд">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </nav>
    </div>

  </div>
</div>

{% include 'partials/contact-cta.twig' %}

{% endblock %}
