{% extends 'layouts/base.twig' %}

{% block title %}Отзывы — {{ siteName }}{% endblock %}

{% block content %}

<div class="cont-border-bottom">
  <div class="container">

    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <a href="index.html">Главная</a> / Отзывы
    </nav>

    <div class="reviews-page-header">
      <h1>Отзывы о клинике Гармония</h1>
      <a href="#" class="btn-leave-review">Оставить отзыв</a>
    </div>

    <div class="reviews-rating-bar">
      <span class="reviews-rating-bar__score">4.8 из 5</span>
      <div class="stars" aria-label="Рейтинг 4.8 из 5">
        {% for i in 1..4 %}
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="#c8a84b" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
        <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <defs><linearGradient id="sg-bar"><stop offset="80%" stop-color="#c8a84b"/><stop offset="80%" stop-color="#d9d9d9"/></linearGradient></defs>
          <path fill="url(#sg-bar)" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </div>
      <span class="reviews-rating-bar__count">На основе 39 оценок</span>
    </div>

    <div class="reviews-sort">
      Сортировать:&nbsp; <a href="#">По умолчанию <svg 
 xmlns="http://www.w3.org/2000/svg"
 xmlns:xlink="http://www.w3.org/1999/xlink"
 width="19px" height="19px">
<path fill-rule="evenodd"  fill="rgb(39, 72, 120)"
 d="M9.500,13.758 L16.258,6.1000 L18.435,9.177 L9.500,18.113 L0.565,9.177 L2.742,6.1000 L9.500,13.758 Z"/>
</svg></a>
    </div>

    {% set reviews = [
      {
        name: 'Татьяна',
        fullStars: 4, halfStar: true, ratingLabel: '4.5 из 5',
        date: '15.05.2025',
        doctor: 'Дерстуганов Виталий Алексеевич',
        text: 'Делала УЗИ у Виталия Алексеевича. Врач очень внимательно провел осмотр, подробно описал ситуацию и дал важные рекомендации по результатам УЗИ. Я редко встречала таких специалистов.'
      },
      {
        name: 'Виктория',
        fullStars: 5, halfStar: false, ratingLabel: '5 из 5',
        date: '19.04.2025',
        doctor: null,
        text: 'Сыну уже 9 лет, а была угроза выкидыша, когда я пришла (а хочется сказать приползла) к Рубцовой Елене Афанасьевне на 4 неделе...после того, как мы решили этот вопрос и малыш "закрепился", я поняла, что останусь на дальнейшее ведение беременности. Для меня было важно оставаться под наблюдением и быть с врачом на связи, а также комфортно придти ко времени, сдать анализы, пройти УЗИ и профильных врачей без очередей, долгих ожиданий записи и пр., как в консультации. Оплата за услугу разбита по частям, что тоже удобно. После, по моему совету воспользовалась услугой и моя родственница.'
      },
      {
        name: 'Михаил',
        fullStars: 5, halfStar: false, ratingLabel: '5 из 5',
        date: '10.04.2025',
        doctor: 'Барковская Ирина Владимировна',
        text: 'Очень доволен клиникой! Записался буквально за час до приёма. Врач внимательно выслушала, назначила необходимые анализы и дала чёткие рекомендации. Всё чисто, современно, персонал вежливый.'
      },
      {
        name: 'Ольга',
        fullStars: 4, halfStar: false, ratingLabel: '4 из 5',
        date: '02.04.2025',
        doctor: null,
        text: 'Хорошая клиника, удобное расположение. Немного пришлось подождать в очереди, но это мелочи. В целом всё понравилось — вежливый персонал, хорошая диагностика. Буду обращаться снова.'
      },
      {
        name: 'Андрей',
        fullStars: 4, halfStar: true, ratingLabel: '4.5 из 5',
        date: '25.03.2025',
        doctor: 'Дерстуганов Виталий Алексеевич',
        text: 'Проходил УЗИ брюшной полости. Доктор провёл исследование очень тщательно, всё подробно объяснил, ответил на все вопросы. Результаты получил сразу. Рекомендую клинику.'
      },
      {
        name: 'Наталья',
        fullStars: 5, halfStar: false, ratingLabel: '5 из 5',
        date: '18.03.2025',
        doctor: null,
        text: 'Наблюдаюсь в клинике «Гармония» уже третий год. За это время ни разу не пожалела о выборе. Врачи внимательные, всегда можно дозвониться и получить консультацию. Отдельное спасибо за быструю запись.'
      },
      {
        name: 'Сергей',
        fullStars: 4, halfStar: false, ratingLabel: '4 из 5',
        date: '11.03.2025',
        doctor: 'Кропачева Анна Сергеевна',
        text: 'Приводили ребёнка к педиатру. Анна Сергеевна — замечательный врач, нашла подход к малышу, провела осмотр и всё объяснила. Единственный минус — нет парковки рядом, но с качеством помощи это несравнимо.'
      },
      {
        name: 'Анна',
        fullStars: 5, halfStar: false, ratingLabel: '5 из 5',
        date: '05.03.2025',
        doctor: null,
        text: 'Отличная клиника! Была на консультации акушера-гинеколога. Врач уделила мне достаточно времени, ответила на все вопросы, успокоила. Всё новое, чисто. Буду рекомендовать всем знакомым.'
      },
      {
        name: 'Дмитрий',
        fullStars: 4, halfStar: true, ratingLabel: '4.5 из 5',
        date: '26.02.2025',
        doctor: 'Дерстуганов Виталий Алексеевич',
        text: 'Сделал УЗИ сердца. Специалист очень грамотный, объяснил всё доступным языком. Запись прошла без каких-либо проблем, время приёма соблюдено. Клиника производит приятное впечатление.'
      },
      {
        name: 'Елена',
        fullStars: 5, halfStar: false, ratingLabel: '5 из 5',
        date: '19.02.2025',
        doctor: 'Барковская Ирина Владимировна',
        text: 'Ирина Владимировна — настоящий профессионал своего дела. Ведёт беременность вдумчиво, всегда на связи. Всей семьёй благодарны клинике за качественную помощь и человеческое отношение.'
      },
      {
        name: 'Алексей',
        fullStars: 4, halfStar: false, ratingLabel: '4 из 5',
        date: '12.02.2025',
        doctor: null,
        text: 'Сдавал анализы и проходил осмотр. Результаты получил уже на следующий день, всё чётко и без задержек. Сервис на высоком уровне, персонал вежливый и внимательный.'
      },
      {
        name: 'Ирина',
        fullStars: 5, halfStar: false, ratingLabel: '5 из 5',
        date: '05.02.2025',
        doctor: 'Кропачева Анна Сергеевна',
        text: 'Регулярно приходим с дочкой к Анне Сергеевне. Она всегда внимательно осматривает ребёнка, объясняет каждый момент, не торопит. Именно такой врач нужен маленьким пациентам!'
      }
    ] %}

    <div class="reviews-list">
      {% for review in reviews %}
      <div class="review-card">
        <h2 class="review-card__name">{{ review.name }}</h2>
        <div class="review-card__meta">
          <div class="stars" aria-label="Рейтинг {{ review.ratingLabel }}">
            {% for i in 1..review.fullStars %}
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true"><path fill="#c8a84b" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
            {% if review.halfStar %}
            <svg viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
              <defs><linearGradient id="sg-{{ loop.index }}"><stop offset="50%" stop-color="#c8a84b"/><stop offset="50%" stop-color="#d9d9d9"/></linearGradient></defs>
              <path fill="url(#sg-{{ loop.index }})" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {% endif %}
          </div>
          <span class="review-card__date">от {{ review.date }}</span>
        </div>
        <hr class="review-card__divider">
        {% if review.doctor %}
        <p class="review-card__doctor">Врач:&nbsp; <a href="#">{{ review.doctor }}</a></p>
        {% endif %}
        <p class="review-card__text">{{ review.text }}</p>
      </div>
      {% endfor %}
    </div>

    <div class="list-footer">
      <a href="#" class="btn-show-more">Показать еще</a>

      <nav class="pg" aria-label="Пагинация">
        <a href="#" class="pg__item" aria-label="Назад">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </a>
        <a href="#" class="pg__item pg__item--active">1</a>
        <a href="#" class="pg__item">2</a>
        <a href="#" class="pg__item">3</a>
        <a href="#" class="pg__item">4</a>
        <span class="pg__item pg__item--dots">...</span>
        <a href="#" class="pg__item">12</a>
        <a href="#" class="pg__item pg__item--filled" aria-label="Вперёд">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </nav>
    </div>

  </div>
</div>

{% include 'partials/contact-cta.twig' %}

{% endblock %}
