{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {

  // ─── Swiper: Reviews ──────────────────────────────────────────────────────────
  new Swiper('.reviews-slider__swiper', {
    slidesPerView: 1,
    spaceBetween: 24,
    navigation: {
      prevEl: '.reviews-slider__prev',
      nextEl: '.reviews-slider__next',
    },
  });

  // ─── Swiper: Diseases ─────────────────────────────────────────────────────────
  new Swiper('.gyno-diseases__swiper', {
    slidesPerView: 1,
    spaceBetween: 20,
    navigation: {
      prevEl: '.gyno-diseases__prev',
      nextEl: '.gyno-diseases__next',
    },
    breakpoints: {
      480: { slidesPerView: 2 },
      768: { slidesPerView: 3 },
      992: { slidesPerView: 4 },
    },
  });

  // ─── FAQ chevron ──────────────────────────────────────────────────────────────
  document.querySelectorAll('.gyno-faq__question').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var expanded = this.getAttribute('aria-expanded') === 'true';
      this.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      this.classList.toggle('is-open', !expanded);
    });
  });

  // ─── Smooth scroll for anchor subnav ──────────────────────────────────────────
  document.querySelectorAll('.gyno-subnav__link[href^="#"]').forEach(function (link) {
    link.addEventListener('click', function (e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        var top = target.getBoundingClientRect().top + window.pageYOffset - 80;
        window.scrollTo({ top: Math.max(0, top), behavior: 'smooth' });
      }
    });
  });

  // ─── Prices: data ─────────────────────────────────────────────────────────────
  var PRICES = [
    {promo: true,  name: 'Пакет услуг: прием гинеколога + узи в гинекологии + мазок на цитологию + забор биоматериала', price: '3 800'},
    {name: 'Биопсия влагалища (без учета стоимости гистологического исследования материала)',   price: '2 000'},
    {name: 'Биопсия вульвы (без учета стоимости гистологического исследования материала)',      price: '2 000'},
    {name: 'Биопсия матки (вакуумаспирация)',                                                   price: '2 800'},
    {name: 'Биопсия шейки матки (прицельная): анестезия, кольпоскопия, забор материала',        price: '2 300'},
    {name: 'Бужирование цервикального канала',                                                  price: '1 200'},
    {name: 'Бужирование цервикального канала после конизации шейки матки',                      price: '1 200'},
    {name: 'Введение ВМС',                                                                      price: '1 800'},
    {name: 'Введение внутриматочной спирали "Мирена" (спираль пациента)',                        price: '3 500'},
    {name: 'Взятие мазков',                                                                     price: '300'},
    {name: 'Гинекологический массаж (1 процедура)',                                             price: '800'},
    {name: 'Гистероскопия диагностическая',                                                     price: '8 500'},
    {name: 'Диатермокоагуляция шейки матки',                                                    price: '2 500'},
    {name: 'Забор материала для ПЦР-исследования',                                              price: '350'},
    {name: 'Извлечение ВМС (простое)',                                                           price: '1 000'},
    {name: 'Извлечение ВМС (сложное)',                                                           price: '2 500'},
    {name: 'Кольпоскопия простая',                                                              price: '1 500'},
    {name: 'Кольпоскопия расширенная',                                                          price: '2 000'},
    {name: 'Консультация гинеколога первичная',                                                 price: '1 500'},
    {name: 'Консультация гинеколога повторная',                                                 price: '1 200'},
    {name: 'Лечение эрозии шейки матки (радиоволновой метод)',                                  price: '4 500'},
    {name: 'Мазок на флору',                                                                    price: '200'},
    {name: 'Мазок на онкоцитологию',                                                            price: '500'},
    {name: 'Медикаментозное прерывание беременности (до 6 недель)',                             price: '5 500'},
    {name: 'Осмотр гинеколога',                                                                 price: '900'},
    {name: 'Плазмолифтинг в гинекологии',                                                       price: '3 500'},
    {name: 'Полипэктомия цервикального канала',                                                 price: '3 000'},
    {name: 'Санация влагалища',                                                                 price: '600'},
    {name: 'УЗИ органов малого таза (трансвагинальное)',                                        price: '1 200'},
    {name: 'УЗИ органов малого таза (трансабдоминальное)',                                      price: '1 000'},
    {name: 'УЗИ молочных желёз',                                                                price: '1 100'},
    {name: 'Удаление кисты бартолиновой железы',                                                price: '5 000'},
    {name: 'Удаление полипа влагалища',                                                         price: '2 800'},
    {name: 'Химическая коагуляция шейки матки (Солковагин)',                                    price: '1 800'},
    {name: 'Цервикальный скрининг (ВПЧ-тест)',                                                  price: '1 800'},
    {name: 'Эхогидросальпингоскопия',                                                           price: '3 500'},
  ];

  var PER_PAGE   = 10;
  var curPage    = 1;
  var filtered   = PRICES;

  var tbody      = document.getElementById('prices-tbody');
  var pgNav      = document.getElementById('prices-pg');
  var searchInput = document.querySelector('.gyno-prices__search input');

  if (!tbody || !pgNav || !searchInput) return;

  // ─── Render table rows ────────────────────────────────────────────────────────
  function renderRows() {
    var start = (curPage - 1) * PER_PAGE;
    var page  = filtered.slice(start, start + PER_PAGE);

    if (!page.length) {
      tbody.innerHTML = '<tr><td colspan="2" style="padding:20px 0;color:#999;text-align:center;">Услуги не найдены</td></tr>';
      return;
    }

    tbody.innerHTML = page.map(function (item) {
      if (item.promo) {
        return '<tr class="gyno-prices__row--promo">'
          + '<td><span class="gyno-prices__badge">Акция</span>'
          + '<a href="#">' + item.name + '</a></td>'
          + '<td class="gyno-prices__val--promo">' + item.price + ' ₽</td></tr>';
      }
      return '<tr><td>' + item.name + '</td><td>' + item.price + ' ₽</td></tr>';
    }).join('');
  }

  // ─── Render pagination ────────────────────────────────────────────────────────
  function renderPg() {
    var total = Math.max(1, Math.ceil(filtered.length / PER_PAGE));

    if (total <= 1) { pgNav.innerHTML = ''; return; }

    var nums;
    if (total <= 7) {
      nums = Array.from({length: total}, function (_, i) { return i + 1; });
    } else if (curPage <= 4) {
      nums = [1, 2, 3, 4, 5, '…', total];
    } else if (curPage >= total - 3) {
      nums = [1, '…', total - 4, total - 3, total - 2, total - 1, total];
    } else {
      nums = [1, '…', curPage - 1, curPage, curPage + 1, '…', total];
    }

    var prevSVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="15 18 9 12 15 6"></polyline></svg>';
    var nextSVG = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="14" height="14"><polyline points="9 18 15 12 9 6"></polyline></svg>';

    var html = '<a href="#" class="pg__item" data-dir="-1" aria-label="Назад">' + prevSVG + '</a>';

    nums.forEach(function (n) {
      if (n === '…') {
        html += '<span class="pg__item pg__item--dots">…</span>';
      } else {
        html += '<a href="#" class="pg__item' + (n === curPage ? ' pg__item--active' : '') + '" data-pg="' + n + '">' + n + '</a>';
      }
    });

    html += '<a href="#" class="pg__item pg__item--filled" data-dir="1" aria-label="Вперёд">' + nextSVG + '</a>';
    pgNav.innerHTML = html;

    pgNav.querySelectorAll('[data-pg]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        goTo(parseInt(this.getAttribute('data-pg')));
      });
    });

    pgNav.querySelectorAll('[data-dir]').forEach(function (el) {
      el.addEventListener('click', function (e) {
        e.preventDefault();
        var next = curPage + parseInt(this.getAttribute('data-dir'));
        var total = Math.ceil(filtered.length / PER_PAGE);
        if (next >= 1 && next <= total) goTo(next);
      });
    });
  }

  function goTo(page) {
    curPage = page;
    renderRows();
    renderPg();
  }

  // ─── Search ───────────────────────────────────────────────────────────────────
  searchInput.addEventListener('input', function () {
    var q = this.value.trim().toLowerCase();
    filtered = q
      ? PRICES.filter(function (item) { return item.name.toLowerCase().indexOf(q) !== -1; })
      : PRICES;
    curPage = 1;
    renderRows();
    renderPg();
  });

  // ─── Init ─────────────────────────────────────────────────────────────────────
  renderRows();
  renderPg();

});
</script>
{% endblock %}
