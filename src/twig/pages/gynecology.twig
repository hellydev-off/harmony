  <section class="gyno-intro">
    <div class="container">
      <div class="gyno-intro__bg">
        <nav class="gyno-subnav__inner">
        <a href="#povod" class="gyno-subnav__link">Повод обратиться к врачу</a>
        <a href="#stoimost" class="gyno-subnav__link">Стоимость</a>
