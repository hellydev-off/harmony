{% extends 'layouts/base.twig' %}

{% block title %}Новости — {{ siteName }}{% endblock %}

{% block content %}

<div class="cont-border-bottom">
  <div class="container">

    <nav class="breadcrumb-nav" aria-label="Breadcrumb">
      <a href="index.html">Главная</a> / Новости
    </nav>

    <h1 class="page-title">Новости</h1>

    <div class="news-list">

      {% set newsItems = [
        { title: 'График работы в праздничные дни в мае',         date: '23.04.2026', excerpt: 'Сообщаем об изменениях в графике работы клиники «Гармония» в преддверии майских праздников!' },
        { title: 'Новые специалисты в нашей клинике',             date: '15.04.2026', excerpt: 'Рады сообщить о пополнении команды клиники «Гармония» новыми высококвалифицированными врачами.' },
        { title: 'Акция «18 показателей здоровья» + витамин D',   date: '10.04.2026', excerpt: 'По многочисленным просьбам пациентов мы вновь запускаем популярную комплексную акцию.' },
        { title: 'Изменения в графике приёма врачей',             date: '05.04.2026', excerpt: 'Сообщаем об изменениях в расписании приёма ряда специалистов в апреле 2026 года.' },
        { title: 'Открытие обновлённого педиатрического кабинета', date: '28.03.2026', excerpt: 'В клинике завершился ремонт и переоснащение педиатрического кабинета новейшим оборудованием.' },
        { title: 'Семинар по женскому здоровью',                  date: '20.03.2026', excerpt: 'Приглашаем на образовательный семинар по вопросам женского репродуктивного здоровья.' },
        { title: 'Новое оборудование для УЗИ-диагностики',        date: '14.03.2026', excerpt: 'Клиника «Гармония» приобрела ультразвуковой аппарат последнего поколения для точной диагностики.' },
        { title: 'Информация о профилактических прививках',       date: '07.03.2026', excerpt: 'Напоминаем о важности своевременной вакцинации и информируем о доступных прививках.' },
        { title: 'Партнёрство с лабораторией KDL',                date: '28.02.2026', excerpt: 'Клиника «Гармония» заключила соглашение с лабораторией KDL для расширения спектра анализов.' },
        { title: 'Приём нутрициолога',                            date: '20.02.2026', excerpt: 'В клинике начала вести приём нутрициолог Сыромолотова Галина Анатольевна.' },
        { title: 'День открытых дверей',                          date: '14.02.2026', excerpt: 'Приглашаем посетить день открытых дверей и познакомиться с клиникой и её специалистами.' },
        { title: 'Программа лояльности для пациентов',            date: '07.02.2026', excerpt: 'Для пациентов, наблюдающихся в клинике более года, действует программа лояльности со скидками.' },
        { title: 'Онлайн-запись к врачу',                         date: '31.01.2026', excerpt: 'Записаться на приём к любому специалисту клиники теперь можно онлайн через сайт или приложение.' },
        { title: 'График работы в январские праздники',           date: '25.01.2026', excerpt: 'Сообщаем о режиме работы клиники «Гармония» в период новогодних и январских праздников.' },
        { title: 'Запуск мобильного приложения',                  date: '18.01.2026', excerpt: 'Рады представить новое мобильное приложение для удобной записи и онлайн-консультаций.' },
        { title: 'Итоги работы за 2025 год',                      date: '10.01.2026', excerpt: 'Подводим итоги успешного года: более 15 000 пациентов, новые врачи и современное оборудование.' }
      ] %}

      {% for item in newsItems %}
      <div class="news-list-item">
        <div class="news-list-item__thumb">
          <img src="/images/doctors/d_kaleidoscope.svg" alt="">
        </div>
        <div class="news-list-item__body">
          <a href="news-detail.html" class="news-list-item__title">{{ item.title }}</a>
          <span class="news-list-item__date-badge">{{ item.date }}</span>
          <p class="news-list-item__excerpt">{{ item.excerpt }}</p>
          <a href="news-detail.html" class="news-list-item__link">Читать подробнее</a>
        </div>
      </div>
      {% endfor %}

    </div>

    <div class="list-footer">
      <a href="#" class="btn-show-more">Показать еще</a>

      <nav class="pg" aria-label="Пагинация">
        <a href="#" class="pg__item" aria-label="Назад">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </a>
        <a href="#" class="pg__item pg__item--active">1</a>
        <a href="#" class="pg__item">2</a>
        <a href="#" class="pg__item">3</a>
        <a href="#" class="pg__item">4</a>
        <span class="pg__item pg__item--dots">...</span>
        <a href="#" class="pg__item">12</a>
        <a href="#" class="pg__item pg__item--filled" aria-label="Вперёд">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </a>
      </nav>
    </div>

  </div>
</div>

{% include 'partials/contact-cta.twig' %}

{% endblock %}
