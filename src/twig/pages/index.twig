{% extends 'layouts/base.twig' %}

{% block title %}Главная — {{ siteName }}{% endblock %}

{% block content %}

{% include 'partials/hero-banner.twig' %}

<div class="bg cont-border-bottom">
  {% include 'partials/services.twig' %}
</div>

{% include 'partials/about-center.twig' %}

<div class="cont-border">
  {% include 'partials/about-text.twig' %}
  {% include 'partials/specialists.twig' %}
  {% include 'partials/specializations.twig' %}
  {% include 'partials/new-doctors.twig' %}
  {% include 'partials/children-banner.twig' %}
  {% include 'partials/news.twig' %}
</div>

{% include 'partials/contact-cta.twig' %}

{% endblock %}

{% block scripts %}
<script>
  (function () {
    new Swiper('.js-hero-swiper', {
      loop: true,
      autoplay: { delay: 5000, disableOnInteraction: false },
      pagination: { el: '.js-hero-swiper .swiper-pagination', clickable: true },
    });

    new Swiper('.js-services-swiper', {
      slidesPerView: 1,
      spaceBetween: 20,
      navigation: {
        prevEl: '.js-services-prev',
        nextEl: '.js-services-next',
      },
      breakpoints: {
        576: { slidesPerView: 2 },
        992: { slidesPerView: 3 },
        1200: { slidesPerView: 4 },
      },
    });

    new Swiper('.js-room-swiper', {
      loop: true,
      pagination: { el: '.js-room-swiper .swiper-pagination', clickable: true },
    });

    new Swiper('.js-specialists-swiper', {
      slidesPerView: 1,
      spaceBetween: 24,
      navigation: {
        prevEl: '.js-specialists-prev',
        nextEl: '.js-specialists-next',
      },
      breakpoints: {
        576: { slidesPerView: 2 },
        992: { slidesPerView: 3 },
      },
    });

    new Swiper('.js-new-doctors-swiper', {
      slidesPerView: 1,
      spaceBetween: 24,
      navigation: {
        prevEl: '.js-new-doctors-prev',
        nextEl: '.js-new-doctors-next',
      },
      breakpoints: {
        768: { slidesPerView: 2 },
      },
    });

    new Swiper('.js-children-swiper', {
      loop: true,
      autoplay: { delay: 6000 },
      pagination: { el: '.js-children-swiper .swiper-pagination', clickable: true },
    });

    new Swiper('.js-news-swiper', {
      slidesPerView: 1,
      spaceBetween: 24,
      navigation: {
        prevEl: '.js-news-prev',
        nextEl: '.js-news-next',
      },
      breakpoints: {
        576: { slidesPerView: 2 },
        992: { slidesPerView: 3 },
      },
    });
  })();
</script>
{% endblock %}
