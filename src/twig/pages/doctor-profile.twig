{% extends 'layouts/base.twig' %}

{% block title %}
  Кропачева А.С. — Врачи — {{ siteName }}
{% endblock %}

{% block content %}
  <div class="cont-border-bottom">
    <div class="container">

      <nav class="breadcrumb-nav">
        <a href="index.html">Главная</a>
        <span class="breadcrumb-nav__sep">/</span>
        <a href="doctors.html">Врачи</a>
        <span class="breadcrumb-nav__sep">/</span>
        <span>Кропачева А.С.</span>
      </nav>

      {# ─── Герой врача ────────────────────────────────────────────────────────── #}
      <div class="dp-hero">
        <div class="dp-hero__photo">
          <img src="/images/doctors/new/anna.png" alt="Кропачева Анна Сергеевна" />
        </div>

        <div class="dp-hero__info">
          <h1 class="dp-hero__name">Кропачева Анна Сергеевна</h1>

          <p class="dp-hero__spec-label">Специализация:</p>
          <p class="dp-hero__spec">Педиатр, Педиатр-пульмонолог</p>

          <div class="dp-hero__meta">
            <div class="dp-hero__meta-item">
              <span class="dp-hero__meta-label">Стаж:</span>
              <span class="dp-hero__meta-value">7 лет</span>
            </div>
            <div class="dp-hero__meta-item">
              <span class="dp-hero__meta-label">Стоимость приема:</span>
              <span class="dp-hero__meta-value">от 1900 ₽</span>
            </div>
          </div>

          <p class="dp-hero__reviews">
            Нет отзывов
            <span class="dp-hero__reviews-sep">|</span>
            <a href="#reviews" class="dp-hero__reviews-link">Добавить отзыв</a>
          </p>

          <a href="#" class="dp-hero__btn">Записаться на прием</a>
        </div>
      </div>

      {# ─── Дипломы и сертификаты ──────────────────────────────────────────────── #}
      <section class="dp-section">
        <h2 class="dp-section__title">Дипломы и сертификаты:</h2>

        <div class="dp-diplomas">
          <div class="dp-diplomas__row">
            <span class="dp-diplomas__year">2019</span>
            <span class="dp-diplomas__text">«Педиатр» диплом специалиста, Тверской государственный медицинский университет, ординатура</span>
          </div>
          <div class="dp-diplomas__row">
            <span class="dp-diplomas__year">2024</span>
            <span class="dp-diplomas__text">«Педиатрия», Тверской государственный медицинский университет, ординатура</span>
          </div>
          <div class="dp-diplomas__row">
            <span class="dp-diplomas__year">2025</span>
            <span class="dp-diplomas__text">«Пульмонология» диплом о профессиональной переподготовке, Российский университет дружбы народов имени Патриса Лумумбы г. Москвы</span>
          </div>
          <div class="dp-diplomas__row">
            <span class="dp-diplomas__year">2025</span>
            <span class="dp-diplomas__text">Удостоверение о повышении квалификации «Пульмонология детского возраста»</span>
          </div>
          <div class="dp-diplomas__row dp-diplomas__row--accred">
            <span class="dp-diplomas__year"></span>
            <span class="dp-diplomas__text">
              <a href="#" class="dp-diplomas__accred-link">Свидетельство об аккредитации 7725 033031954 от 04.07.2025</a>
              <span class="dp-diplomas__accred-inst">«Пульмонология», Российский университет дружбы народов имени Патриса Лумумбы</span>
            </span>
          </div>
          <div class="dp-diplomas__row dp-diplomas__row--accred">
            <span class="dp-diplomas__year"></span>
            <span class="dp-diplomas__text">
              <a href="#" class="dp-diplomas__accred-link">Свидетельство об аккредитации 6924 032074800 от 15.07.2024</a>
              <span class="dp-diplomas__accred-inst">«Педиатрия»</span>
            </span>
          </div>
        </div>
      </section>

      {# ─── Отзывы ─────────────────────────────────────────────────────────────── #}
      <section class="dp-section dp-reviews" id="reviews">
        <h2 class="dp-section__title">Отзывы о враче:</h2>
        <p class="dp-reviews__empty">У этого врача пока нет отзывов. Помогите другим пациентам — оставьте первый отзыв!</p>
        <a href="#" class="dp-reviews__btn">Добавить отзыв</a>
      </section>

    </div>
  </div>

  {% include 'partials/contact-cta.twig' %}
{% endblock %}

{% block scripts %}
<script>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var name   = params.get('name');
    var photo  = params.get('photo');

    if (name) {
      document.querySelector('.dp-hero__name').textContent = name;

      // Breadcrumb: "Иванов И.И."
      var parts = name.trim().split(/\s+/);
      var short = parts[0];
      if (parts[1]) short += ' ' + parts[1][0] + '.';
      if (parts[2]) short += parts[2][0] + '.';
      document.querySelector('.breadcrumb-nav span:last-child').textContent = short;
    }

    if (photo) {
      var img = document.querySelector('.dp-hero__photo img');
      if (img) {
        img.src   = photo;
        img.alt   = name || '';
      }
    } else if (name) {
      // No photo — show placeholder
      var photoWrap = document.querySelector('.dp-hero__photo');
      if (photoWrap) {
        photoWrap.innerHTML =
          '<svg viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:65%;opacity:.22;display:block;margin:auto;">' +
            '<ellipse cx="40" cy="30" rx="22" ry="24" fill="#BBBBBB"/>' +
            '<path d="M5 95C5 72 75 72 75 95" stroke="#BBBBBB" stroke-width="8" fill="none" stroke-linecap="round"/>' +
          '</svg>';
        photoWrap.style.alignItems = 'center';
        photoWrap.style.justifyContent = 'center';
        photoWrap.style.minHeight = '340px';
      }
    }
  })();
</script>
{% endblock %}
