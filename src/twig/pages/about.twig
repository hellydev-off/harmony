{% extends 'layouts/base.twig' %}

{% block title %}О клинике — {{ siteName }}{% endblock %}

{% block content %}
<div class="cont-border-bottom">
  <div class="container">
    <nav class="breadcrumb-nav">
      <a href="index.html">Главная</a>
      <span class="breadcrumb-nav__sep">/</span>
      <span>О клинике</span>
    </nav>
    <h1 class="page-title">О клинике</h1>
  </div>

  {% include 'partials/about-intro.twig' %}
</div>

{% include 'partials/about-center.twig' %}

<div class="cont-border">
  {% include 'partials/clinic-legal.twig' %}
  {% include 'partials/key-specialists.twig' %}
  {% include 'partials/care-text.twig' %}
  {% include 'partials/control-authorities.twig' %}
  {% include 'partials/documents-banner.twig' %}
  {% include 'partials/certificates.twig' %}
  {% include 'partials/partners.twig' %}
  {% include 'partials/prodoctors.twig' %}
</div>

{% include 'partials/contact-cta.twig' %}
{% endblock %}

{% block scripts %}
<script>
  (function () {
    new Swiper('.js-about-room-swiper', {
      loop: true,
      pagination: { el: '.js-about-room-swiper .swiper-pagination', clickable: true },
    });

    new Swiper('.js-care-swiper', {
      slidesPerView: 1,
      spaceBetween: 20,
      navigation: {
        prevEl: '.care-swiper-prev',
        nextEl: '.care-swiper-next',
      },
      breakpoints: {
        768: { slidesPerView: 2 },
      },
    });

    new Swiper('.js-partners-swiper', {
      slidesPerView: 2,
      spaceBetween: 20,
      navigation: {
        prevEl: '.js-partners-prev',
        nextEl: '.js-partners-next',
      },
      breakpoints: {
        768: { slidesPerView: 3 },
        992: { slidesPerView: 4 },
      },
    });
  })();
</script>
{% endblock %}
