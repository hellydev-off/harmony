{% extends 'layouts/base.twig' %}

{% block title %}
  Врачи — {{ siteName }}
{% endblock %}

{% block content %}
  <div class="cont-border-bottom">
    <div class="container">
      <nav class="breadcrumb-nav">
        <a href="index.html">Главная</a>
        <span class="breadcrumb-nav__sep">/</span>
        <span>Врачи</span>
      </nav>
      <h1 class="page-title">Врачи</h1>
    </div>

    <section class="featured-doctors">
      <div class="container">
        <div class="featured-doctors__grid">
          <div class="doctor-featured" data-doctor-name="Барковская Ирина Владимировна" data-doctor-photo="/images/doctors/glav.png">
            <div class="doctor-featured__photo">
              <img src="/images/doctors/glav.png" alt="Барковская Ирина Владимировна" />
            </div>
            <div class="doctor-featured__info">
              <p class="doctor-featured__name">
                Барковская<br />Ирина Владимировна
              </p>
              <p class="doctor-featured__role">
                Главный врач, акушер-гинеколог, врач высшей категории
              </p>
            </div>
          </div>

          <div class="doctor-featured" data-doctor-name="Троян Юлиана Викторовна" data-doctor-photo="/images/doctors/director.png">
            <div class="doctor-featured__photo">
              <img src="/images/doctors/director.png" alt="Троян Юлиана Викторовна" />
            </div>
            <div class="doctor-featured__info">
              <p class="doctor-featured__name">
                Троян<br />Юлиана Викторовна
              </p>
              <p class="doctor-featured__role">
                Исполнительный директор
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {# ─── Фильтр ─────────────────────────────────────────────────────────────────── #}
    <div class="doctors-filter">
      <div class="container">
        <div class="doctors-filter__inner">
          <label class="doctors-filter__search">
            <svg class="doctors-filter__icon" width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M24.9777 22.7343L20.0527 17.8073C23.7377 12.8843 22.7327 5.90526 17.8087 2.22026C12.8847 -1.46374 5.90569 -0.459742 2.22069 4.46426C-1.46431 9.38826 -0.459312 16.3663 4.46469 20.0513C8.41969 23.0113 13.8527 23.0113 17.8087 20.0513L22.7357 24.9783C23.3547 25.5973 24.3587 25.5973 24.9777 24.9783C25.5967 24.3593 25.5967 23.3553 24.9777 22.7363V22.7343ZM11.1777 19.1003C6.80069 19.1003 3.25369 15.5533 3.25369 11.1773C3.25369 6.80126 6.80069 3.25326 11.1777 3.25326C15.5537 3.25326 19.1017 6.80126 19.1017 11.1773C19.0977 15.5513 15.5527 19.0963 11.1777 19.1003Z" fill="currentColor" />
            </svg>
            <input type="text" placeholder="Найти врача ..." />
          </label>
          <div class="doctors-filter__sep"></div>
          <button class="doctors-filter__specialty">
            <svg class="doctors-filter__icon" width="29" height="29" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M28.537 10.704C28.545 8.734 26.955 7.13 24.985 7.122C23.015 7.113 21.411 8.705 21.403 10.675C21.397 12.192 22.351 13.548 23.781 14.054V19.03C23.781 22.971 20.587 26.166 16.647 26.166C12.706 26.166 9.512 22.971 9.512 19.03V18.935C13.602 18.342 16.639 14.838 16.647 10.704V5.947C16.643 2.664 13.983 0.004 10.701 0C10.045 0 9.512 0.533 9.512 1.189C9.512 1.846 10.045 2.379 10.701 2.379C12.671 2.379 14.268 3.976 14.268 5.947V10.704C14.268 13.989 11.607 16.652 8.323 16.652C5.04 16.652 2.378 13.989 2.378 10.704V5.947C2.378 3.976 3.975 2.379 5.945 2.379C6.602 2.379 7.134 1.846 7.134 1.189C7.134 0.533 6.602 0 5.945 0C2.663 0.004 0.004 2.664 0 5.947V10.704C0.008 14.838 3.044 18.342 7.134 18.935V19.03C7.134 24.285 11.393 28.545 16.647 28.545C21.9 28.545 26.159 24.285 26.159 19.03V14.054C27.579 13.552 28.531 12.211 28.537 10.704ZM24.97 11.894C24.313 11.894 23.781 11.361 23.781 10.704C23.781 10.048 24.313 9.515 24.97 9.515C25.627 9.515 26.159 10.048 26.159 10.704C26.159 11.361 25.627 11.894 24.97 11.894Z" fill="currentColor" />
            </svg>
            <span>Специальности</span>
            <svg
              class="doctors-filter__chevron"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
        </div>
      </div>
    </div>

    {# ─── Сетка врачей ───────────────────────────────────────────────────────────── #}
    <section class="doctors-grid-section">
      <div class="container">
        <div class="doctors-grid">
          <div class="dr-card" data-doctor-name="Аваева Татьяна Владимировна" data-doctor-photo="">
            <div class="dr-card__photo dr-card__photo--placeholder">
              <svg viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="40" cy="30" rx="22" ry="24" fill="#BBBBBB" />
                <path d="M5 95C5 72 75 72 75 95" stroke="#BBBBBB" stroke-width="8" fill="none" stroke-linecap="round" />
              </svg>
            </div>
            <p class="dr-card__name">Аваева Татьяна Владимировна</p>
            <p class="dr-card__spec">Педиатр, Инфекционист, заслуженный врач РФ, врач высшей категории</p>
          </div>

          <div class="dr-card" data-doctor-name="Вронец Наталья Валерьевна" data-doctor-photo="/images/doctors/natal.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/natal.png" alt="Вронец Наталья Валерьевна" />
            </div>
            <p class="dr-card__name">Вронец Наталья Валерьевна</p>
            <p class="dr-card__spec">Пульмонолог</p>
          </div>

          <div class="dr-card" data-doctor-name="Каталымов Сергей Юрьевич" data-doctor-photo="/images/doctors/sergey.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/sergey.png" alt="Каталымов Сергей Юрьевич" />
            </div>
            <p class="dr-card__name">Каталымов Сергей Юрьевич</p>
            <p class="dr-card__spec">ЛОР, врач высшей категории</p>
          </div>

          <div class="dr-card" data-doctor-name="Кононова Алла Геннадьевна" data-doctor-photo="/images/doctors/alla.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/alla.png" alt="Кононова Алла Геннадьевна" />
            </div>
            <p class="dr-card__name">Кононова Алла Геннадьевна</p>
            <p class="dr-card__spec">Гастроэнтеролог, врач высшей категории, кандидат медицинских наук</p>
          </div>

          <div class="dr-card" data-doctor-name="Сыромолотова Галина Анатольевна" data-doctor-photo="/images/doctors/new/galinf.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/new/galinf.png" alt="Сыромолотова Галина Анатольевна" />
            </div>
            <p class="dr-card__name">Сыромолотова Галина Анатольевна</p>
            <p class="dr-card__spec">Нутрициолог, терапевт, врач первой категории</p>
          </div>

          <div class="dr-card" data-doctor-name="Кропачева Анна Сергеевна" data-doctor-photo="/images/doctors/new/anna.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/new/anna.png" alt="Кропачева Анна Сергеевна" />
            </div>
            <p class="dr-card__name">Кропачева Анна Сергеевна</p>
            <p class="dr-card__spec">Педиатр, педиатр-пульмонолог</p>
          </div>

          <div class="dr-card" data-doctor-name="Аваева Татьяна Владимировна" data-doctor-photo="">
            <div class="dr-card__photo dr-card__photo--placeholder">
              <svg viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="40" cy="30" rx="22" ry="24" fill="#BBBBBB" />
                <path d="M5 95C5 72 75 72 75 95" stroke="#BBBBBB" stroke-width="8" fill="none" stroke-linecap="round" />
              </svg>
            </div>
            <p class="dr-card__name">Аваева Татьяна Владимировна</p>
            <p class="dr-card__spec">Педиатр, Инфекционист, заслуженный врач РФ, врач высшей категории</p>
          </div>

          <div class="dr-card" data-doctor-name="Вронец Наталья Валерьевна" data-doctor-photo="/images/doctors/natal.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/natal.png" alt="Вронец Наталья Валерьевна" />
            </div>
            <p class="dr-card__name">Вронец Наталья Валерьевна</p>
            <p class="dr-card__spec">Пульмонолог</p>
          </div>

          <div class="dr-card" data-doctor-name="Каталымов Сергей Юрьевич" data-doctor-photo="/images/doctors/sergey.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/sergey.png" alt="Каталымов Сергей Юрьевич" />
            </div>
            <p class="dr-card__name">Каталымов Сергей Юрьевич</p>
            <p class="dr-card__spec">ЛОР, врач высшей категории</p>
          </div>

          <div class="dr-card" data-doctor-name="Кононова Алла Геннадьевна" data-doctor-photo="/images/doctors/alla.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/alla.png" alt="Кононова Алла Геннадьевна" />
            </div>
            <p class="dr-card__name">Кононова Алла Геннадьевна</p>
            <p class="dr-card__spec">Гастроэнтеролог, врач высшей категории, кандидат медицинских наук</p>
          </div>

          <div class="dr-card" data-doctor-name="Сыромолотова Галина Анатольевна" data-doctor-photo="/images/doctors/new/galinf.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/new/galinf.png" alt="Сыромолотова Галина Анатольевна" />
            </div>
            <p class="dr-card__name">Сыромолотова Галина Анатольевна</p>
            <p class="dr-card__spec">Нутрициолог, терапевт, врач первой категории</p>
          </div>

          <div class="dr-card" data-doctor-name="Кропачева Анна Сергеевна" data-doctor-photo="/images/doctors/new/anna.png">
            <div class="dr-card__photo">
              <img src="/images/doctors/new/anna.png" alt="Кропачева Анна Сергеевна" />
            </div>
            <p class="dr-card__name">Кропачева Анна Сергеевна</p>
            <p class="dr-card__spec">Педиатр, педиатр-пульмонолог</p>
          </div>
        </div>

        <div class="doctors-grid__more">
          <button class="btn-more">Показать ещё</button>
        </div>
      </div>
    </section>
  </div>

  {% include 'partials/contact-cta.twig' %}
{% endblock %}
