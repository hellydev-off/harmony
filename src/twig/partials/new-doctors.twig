{# ─── Наши новые врачи ───────────────────────────────────────────────────────── #}
<section class="section new-doctors-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Наши новые врачи</h2>
      <div class="swiper-nav">
        <button class="swiper-nav__btn js-new-doctors-prev" aria-label="Назад">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="swiper-nav__btn swiper-nav__btn--next js-new-doctors-next" aria-label="Вперёд">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>

    <div class="swiper js-new-doctors-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="new-doctor-card" data-doctor-name="Сыромолотова Галина Анатольевна" data-doctor-photo="/images/doctors/new/galinf.png">
            <div class="new-doctor-card__photo">
              <img src="/images/doctors/new/galinf.png" alt="Сыромолотова Галина Анатольевна">
            </div>
            <div class="new-doctor-card__info">
              <p class="new-doctor-card__name">Сыромолотова<br>Галина Анатольевна</p>
              <p class="new-doctor-card__spec">Нутрициолог, терапевт, врач первой категории</p>
              <span class="new-doctor-card__link">Подробнее</span>
            </div>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="new-doctor-card" data-doctor-name="Кропачева Анна Сергеевна" data-doctor-photo="/images/doctors/new/anna.png">
            <div class="new-doctor-card__photo">
              <img src="/images/doctors/new/anna.png" alt="Кропачева Анна Сергеевна">
            </div>
            <div class="new-doctor-card__info">
              <p class="new-doctor-card__name">Кропачева<br>Анна Сергеевна</p>
              <p class="new-doctor-card__spec">Педиатр, педиатр-пульмонолог</p>
              <span class="new-doctor-card__link">Подробнее</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
