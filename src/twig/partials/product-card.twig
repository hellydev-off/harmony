<div class="product-card">
  <a href="{{ product.href|default('#') }}" class="product-card__image-link">
    <img class="product-card__image img-responsive" src="{{ product.thumb|default('images/placeholder.png') }}" alt="{{ product.name }}">
  </a>
  <div class="product-card__body">
    <h3 class="product-card__title">
      <a href="{{ product.href|default('#') }}">{{ product.name }}</a>
    </h3>
    <div class="product-card__prices">
      <span class="product-card__price">{{ product.price }} ₽</span>
      {% if product.oldPrice %}
        <span class="product-card__price-old">{{ product.oldPrice }} ₽</span>
      {% endif %}
    </div>
    <div class="product-card__actions">
      {# OpenCart: cart.add() приходит из catalog/view/javascript/common.js #}
      <button type="button" class="btn btn-primary btn-sm btn-block" onclick="cart.add('{{ product.product_id }}');">В корзину</button>
    </div>
  </div>
</div>
