{# ─── Наши специалисты ───────────────────────────────────────────────────────── #}
<section class="section specialists-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Наши специалисты:</h2>
      <div class="section-header__right">
        <a href="doctors.html" class="section-link">Посмотреть всех врачей</a>
        <div class="swiper-nav">
          <button class="swiper-nav__btn js-specialists-prev" aria-label="Назад">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"></polyline>
            </svg>
          </button>
          <button class="swiper-nav__btn swiper-nav__btn--next js-specialists-next" aria-label="Вперёд">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="swiper js-specialists-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="doctor-card" data-doctor-name="Вронец Наталья Валерьевна" data-doctor-photo="/images/doctors/natal.png">
            <div class="doctor-card__photo">
              <img src="/images/doctors/natal.png" alt="Вронец Наталья Валерьевна">
            </div>
            <p class="doctor-card__name">Вронец Наталья Валерьевна</p>
            <p class="doctor-card__specialty">Пульмонолог</p>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="doctor-card" data-doctor-name="Каталымов Сергей Юрьевич" data-doctor-photo="/images/doctors/sergey.png">
            <div class="doctor-card__photo">
              <img src="/images/doctors/sergey.png" alt="Каталымов Сергей Юрьевич">
            </div>
            <p class="doctor-card__name">Каталымов Сергей Юрьевич</p>
            <p class="doctor-card__specialty">ЛОР, врач высшей категории</p>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="doctor-card" data-doctor-name="Кононова Алла Геннадьевна" data-doctor-photo="/images/doctors/alla.png">
            <div class="doctor-card__photo">
              <img src="/images/doctors/alla.png" alt="Кононова Алла Геннадьевна">
            </div>
            <p class="doctor-card__name">Кононова Алла Геннадьевна</p>
            <p class="doctor-card__specialty">Гастроэнтеролог, врач высшей категории, кандидат медицинских наук</p>
          </div>
        </div>
        <div class="swiper-slide">
          <div class="doctor-card" data-doctor-name="Сыромолотова Галина Анатольевна" data-doctor-photo="/images/doctors/new/galinf.png">
            <div class="doctor-card__photo">
              <img src="/images/doctors/new/galinf.png" alt="Сыромолотова Галина Анатольевна">
            </div>
            <p class="doctor-card__name">Сыромолотова Галина Анатольевна</p>
            <p class="doctor-card__specialty">Нутрициолог, терапевт, врач первой категории</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
