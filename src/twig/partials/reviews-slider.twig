{#
  Переиспользуемый слайдер отзывов.
  Переменные (все необязательные):
    title      — заголовок секции (default: 'Отзывы об услуге')
    section_id — id для якорной ссылки (default: 'otzyvy')
    reviews    — массив объектов { author, rating, date, text }
#}

{% set title = title|default('Отзывы об услуге') %}
{% set section_id = section_id|default('otzyvy') %}

{% set reviews = reviews|default([
  {
    author: 'Виктория',
    rating: 4,
    date: 'от 19.04.2025',
    text: 'Сыну уже 9 лет, а была угроза выкидыша, когда я пришла (а хочется сказать приползла) к Рубцовой Елене Афанасьевне на 4 неделе...после того, как мы решили этот вопрос и малыш «закрепился», я поняла, что останусь на дальнейшее ведение беременности. Для меня было важно оставаться под наблюдением и быть с врачом на связи, а также комфортно придти ко времени, сдать анализы, пройти УЗИ и профильных врачей без очередей, долгих ожиданий записи и пр., как в консультации. Было несколько раз, когда пришлось позвонить врачу для консультации и придти на внеплановую проверку.'
  },
  {
    author: 'Анна',
    rating: 5,
    date: 'от 10.03.2025',
    text: 'Очень довольна клиникой! Врачи внимательные, грамотные. Сдала все анализы в одном месте. Особенно понравился подход — никакого осуждения, только помощь и поддержка. Буду рекомендовать всем своим подругам.'
  },
  {
    author: 'Мария',
    rating: 5,
    date: 'от 05.02.2025',
    text: 'Прекрасная клиника! Записалась онлайн, приняли вовремя. Гинеколог очень внимательно выслушала, назначила необходимые анализы. Всё чисто, красиво, персонал вежливый.'
  }
]) %}

<section class="reviews-slider" id="{{ section_id }}">
  <div class="container">
    <h2 class="reviews-slider__title">{{ title }}</h2>

    <div class="reviews-slider__wrap">
      <button class="reviews-slider__arrow reviews-slider__prev" aria-label="Назад">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <div class="reviews-slider__clip">
        <div class="swiper reviews-slider__swiper">
          <div class="swiper-wrapper">
            {% for review in reviews %}
            <div class="swiper-slide">
              <div class="review-card">
                <div class="review-card__header">
                  <span class="review-card__author">{{ review.author }}</span>
                  <span class="review-card__stars">
                    {% for i in 1..5 %}
                      <span class="review-card__star{% if i > review.rating %} review-card__star--empty{% endif %}">★</span>
                    {% endfor %}
                  </span>
                  <span class="review-card__date">{{ review.date }}</span>
                </div>
                <hr class="review-card__divider">
                <p class="review-card__text">{{ review.text }}</p>
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>

      <button class="reviews-slider__arrow reviews-slider__next" aria-label="Вперёд">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>
    </div>

    <div class="reviews-slider__actions">
      <a href="#" class="reviews-slider__btn reviews-slider__btn--primary">Добавить отзыв</a>
      <a href="#" class="reviews-slider__btn reviews-slider__btn--outline">Все отзывы</a>
    </div>
  </div>
</section>
